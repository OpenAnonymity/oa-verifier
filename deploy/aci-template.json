{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "oa-verifier",
      "location": "eastus",
      "properties": {
        "sku": "Confidential",
        "containers": [
          {
            "name": "oa-verifier",
            "properties": {
              "image": "oaverifieracr.azurecr.io/oa-verifier@sha256:14e6927267f2375b9133b1f9931e2f01d9f40bf5eba55b490b97f4df6619ed4c",
              "ports": [
                {
                  "port": 8443,
                  "protocol": "TCP"
                }
              ],
              "environmentVariables": [
                {
                  "name": "MAA_ENDPOINT",
                  "value": "http://localhost:8080/attest/maa"
                },
                {
                  "name": "MAA_PROVIDER_URL",
                  "value": "sharedeus.eus.attest.azure.net"
                },
                {
                  "name": "STATION_REGISTRY_URL",
                  "value": "PLACEHOLDER_WILL_BE_REPLACED"
                },
                {
                  "name": "STATION_REGISTRY_SECRET",
                  "secureValue": "PLACEHOLDER_WILL_BE_REPLACED"
                },
                {
                  "name": "CHALLENGE_MIN_INTERVAL",
                  "value": "PLACEHOLDER_WILL_BE_REPLACED"
                },
                {
                  "name": "CHALLENGE_MAX_INTERVAL",
                  "value": "PLACEHOLDER_WILL_BE_REPLACED"
                }
              ],
              "resources": {
                "requests": {
                  "cpu": 1.0,
                  "memoryInGB": 2.0
                }
              }
            }
          },
          {
            "name": "skr-sidecar",
            "properties": {
              "image": "mcr.microsoft.com/aci/skr@sha256:baa6acf093c011cb26799187b6a535e32bd8248f52dd2cd9c606732b8a23c112",
              "command": [
                "/skr.sh"
              ],
              "ports": [
                {
                  "port": 8080,
                  "protocol": "TCP"
                }
              ],
              "resources": {
                "requests": {
                  "cpu": 0.5,
                  "memoryInGB": 1.0
                }
              }
            }
          }
        ],
        "ipAddress": {
          "type": "Public",
          "ports": [
            {
              "port": 8443,
              "protocol": "TCP"
            }
          ],
          "dnsNameLabel": "oa-verifier"
        },
        "osType": "Linux",
        "restartPolicy": "Always",
        "imageRegistryCredentials": [
          {
            "server": "oaverifieracr.azurecr.io",
            "username": "oaverifieracr",
            "password": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', 'oaverifieracr'), '2023-07-01').passwords[0].value]"
          }
        ],
        "confidentialComputeProperties": {
          "ccePolicy": ""
        }
      }
    }
  ]
}