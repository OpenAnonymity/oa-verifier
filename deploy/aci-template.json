{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_comment": "Reference template - CCE policy is generated dynamically by CI/CD workflow"
  },
  "parameters": {
    "imageDigest": {
      "type": "string",
      "metadata": {
        "description": "Container image digest (from GitHub Actions build)"
      }
    },
    "registryServer": {
      "type": "string",
      "defaultValue": "ghcr.io/openanonymity",
      "metadata": {
        "description": "Container registry server (ghcr.io/OWNER or ACR)"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "oa-verifier",
      "location": "eastus",
      "properties": {
        "sku": "Confidential",
        "containers": [
          {
            "name": "oa-verifier",
            "properties": {
              "image": "[concat(parameters('registryServer'), '/oa-verifier@', parameters('imageDigest'))]",
              "ports": [
                {
                  "port": 443,
                  "protocol": "TCP"
                }
              ],
              "environmentVariables": [
                {
                  "name": "MAA_ENDPOINT",
                  "value": "http://localhost:8080/attest/maa"
                },
                {
                  "name": "MAA_PROVIDER_URL",
                  "value": "sharedeus.eus.attest.azure.net"
                }
              ],
              "resources": {
                "requests": {
                  "cpu": 1.0,
                  "memoryInGB": 2.0
                }
              }
            }
          },
          {
            "name": "skr-sidecar",
            "properties": {
              "image": "mcr.microsoft.com/aci/skr@sha256:baa6acf093c011cb26799187b6a535e32bd8248f52dd2cd9c606732b8a23c112",
              "command": [
                "/skr.sh"
              ],
              "ports": [
                {
                  "port": 8080,
                  "protocol": "TCP"
                }
              ],
              "resources": {
                "requests": {
                  "cpu": 0.5,
                  "memoryInGB": 1.0
                }
              }
            }
          }
        ],
        "ipAddress": {
          "type": "Public",
          "ports": [
            {
              "port": 443,
              "protocol": "TCP"
            }
          ],
          "dnsNameLabel": "oa-verifier"
        },
        "osType": "Linux",
        "restartPolicy": "Always",
        "confidentialComputeProperties": {
          "ccePolicy": ""
        }
      }
    }
  ]
}
