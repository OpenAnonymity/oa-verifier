# Registry configuration
STATION_REGISTRY_URL=http://localhost:xxxx
STATION_REGISTRY_SECRET=your_registry_secret_here

# Challenge interval configuration (seconds)
CHALLENGE_MIN_INTERVAL=300
CHALLENGE_MAX_INTERVAL=600

# Ownership check grace window (seconds)
SUBMIT_KEY_OWNERSHIP_GRACE_SECONDS=60

# Transient failure grace window before unregistering (seconds)
STATION_FAILURE_GRACE_SECONDS=600

# File paths for persistent storage
BANNED_STATIONS_FILE=banned_stations.json

# Concurrency and rate limiting (set via secrets in production)
# MAX_CONCURRENT_REQUESTS=
# RATE_LIMIT_RPS=
# RATE_LIMIT_BURST=

# TLS / ACME (Let's Encrypt) configuration
# TLS_DOMAIN=your.domain.com
# ACME_EMAIL=admin@your.domain.com
# ACME_DNS_PROVIDER=cloudflare
# ACME_STAGING=false
# CF_DNS_API_TOKEN=your_cloudflare_api_token

# Azure attestation (set automatically in ACI Confidential Containers)
# MAA_ENDPOINT=http://localhost:8080/attest/maa
# MAA_PROVIDER_URL=sharedeus.eus.attest.azure.net
# CCE_POLICY_B64=
